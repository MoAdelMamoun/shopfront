# ShopFront is a fully static demo — it runs with ZERO config out of the box.
# These optional variables let you re-brand the demo without touching code.
# Copy to `.env.local` and edit. All are build-time (NEXT_PUBLIC_*) values.

# Store display name (default: "Driftwood & Co.")
NEXT_PUBLIC_STORE_NAME=

# Currency symbol shown before prices (default: "$")
NEXT_PUBLIC_CURRENCY=

# Base path if hosting under a subdirectory, e.g. "/shopfront" for GitHub Pages
# project sites. Leave blank for root hosting (Netlify/Cloudflare/Vercel).
NEXT_PUBLIC_BASE_PATH=
